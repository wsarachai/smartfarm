{
  "web_server": {
    "base_url": "http://localhost:3000",
    "device_id": "jetson_ctrl_01",
    "http_timeout_ms": 2000
  },
  "cadence": {
    "control_tick_ms": 2000,
    "network_every_ticks": 5,
    "dht22_min_interval_ms": 2000
  },
  "thermal": {
    "sysfs_root": "/sys/class/thermal",
    "zone_names": ["CPU-therm", "GPU-therm"]
  },
  "dht22": {
    "gpiochip": "gpiochip0",
    "line_offset": 149,
    "max_retries": 3,
    "stale_after_ms": 30000
  },
  "external_fan": {
    "gpiochip": "gpiochip0",
    "line_offset": 200,
    "active_high": true
  },
  "control": {
    "temp_on_c": 60.0,
    "temp_off_c": 52.0,
    "enclosure_air_on_c": 45.0,
    "enclosure_air_off_c": 40.0,
    "min_on_seconds": 30,
    "min_off_seconds": 30
  },
  "override": {
    "max_duration_minutes": 120
  }
}

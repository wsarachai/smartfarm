{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake configure (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["-S", ".", "-B", "build", "-DCMAKE_BUILD_TYPE=Debug"],
      "problemMatcher": []
    },
    {
      "label": "build (Debug)",
      "type": "shell",
      "command": "cmake",
      "comment": "'--' passthrough, not 'cmake --build -j': the -j flag is CMake 3.12+ and JetPack 4.x ships 3.10.2.",
      "args": ["--build", "build", "--", "-j4"],
      "dependsOn": "cmake configure (Debug)",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    }
  ]
}

{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake configure (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["-S", ".", "-B", "build", "-DCMAKE_BUILD_TYPE=Debug"],
      "problemMatcher": []
    },
    {
      "label": "build (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build", "-j"],
      "dependsOn": "cmake configure (Debug)",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    }
  ]
}

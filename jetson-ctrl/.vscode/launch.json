{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug test_control",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/test_control",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        { "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "preLaunchTask": "build (Debug)"
    },
    {
      "name": "Debug jetson-ctrl daemon",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/jetson-ctrl",
      "args": ["--config", "${workspaceFolder}/config.example.json"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        { "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "preLaunchTask": "build (Debug)"
    }
  ]
}

# Development-only overrides (loaded by `vite dev`, ignored by `vite build`).
#
# Point the pump relay target at the SSH tunnel to the real pump instead of the
# production pump IP. The tunnel maps localhost:8080 -> 192.168.0.4:80 (the pump)
# via the Jetson. Production builds omit this file and fall back to the real IP
# hardcoded in src/features/pump/pumpSettings.js. See web-server/DEV.md.
VITE_PUMP_URL=http://localhost:8080

# Backend dev env. Copy to .env and adjust, then run `npm run dev`
# (uses Node's native --env-file, Node >= 20.6; production uses compose env).
#
# These seed data/settings.json on first boot; once the file exists it wins,
# so edit the Settings page (or delete data/settings.json) to pick up changes.

# Where the persisted dashboard settings live (camera source + pump).
SETTINGS_PATH=./data/settings.json

# Pump target the relay commands. In dev this typically points at the Jetson
# SSH tunnel to the pump (was VITE_PUMP_URL on the client, now server-owned).
PUMP_URL=http://localhost:8080
PUMP_LABEL=Main Pump
PUMP_AUTO_OFF_MINUTES=5

# Camera source prefs (where the browser reads live/snapshot frames).
CAMERA_SOURCE_MODE=relay
CAMERA_STREAM_URL=http://192.168.0.3:81/stream
CAMERA_SNAPSHOT_URL=/api/v1/camera/frame.jpg
